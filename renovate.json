{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":label(renovate)",
    ":timezone(Asia/Tokyo)",
    ":separateMajorReleases",
    ":prHourlyLimit10",
    ":prConcurrentLimit20"
  ],
  "schedule": ["at any time"],
  "rangeStrategy": "update-lockfile",
  "postUpdateOptions": ["gradleUpdate"],
  "enabledManagers": ["gradle", "github-actions", "dockerfile"],
  "packageRules": [
    {
      "description": "Version Catalog (libs.versions.toml) 内の Spring Boot と MyBatis を毎日チェック",
      "matchManagers": ["gradle"],
      "matchPackagePrefixes": [
        "org.springframework.boot",
        "org.mybatis.spring.boot"
      ],
      "groupName": "spring stack",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "description": "その他の依存関係もマイナー・パッチは自動マージ",
      "matchManagers": ["gradle", "github-actions", "dockerfile"],
      "excludePackagePrefixes": ["org.springframework.boot", "org.mybatis.spring.boot"],
      "groupName": "all non-major dependencies",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ],
  "osvVulnerabilityAlerts": true
}